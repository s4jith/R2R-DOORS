# ── Database ──────────────────────────────────────────────────────────────
# MongoDB connection string (e.g. MongoDB Atlas SRV URI)
MONGO_URI=

# ── Cloudflare R2 (S3-compatible object storage) ──────────────────────────
# Create an R2 bucket + an API token with Object Read & Write.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for the bucket — either the r2.dev dev URL or a custom domain.
# Example: https://pub-xxxxxxxx.r2.dev   or   https://cdn.yourdomain.com
R2_PUBLIC_URL=

# ── Admin authentication ──────────────────────────────────────────────────
# Secret used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
ADMIN_USERNAME=admin
# bcrypt hash of the admin password. Generate with: npm run hash-password -- "password"
# Then base64-encode the hash: echo -n "$HASH" | base64
# Paste the base64-encoded value below (dotenv parser misinterprets $2b prefix)
ADMIN_PASSWORD_HASH=
# Session lifetime in seconds (default 28800 = 8 hours)
SESSION_COOKIE_MAX_AGE=28800
